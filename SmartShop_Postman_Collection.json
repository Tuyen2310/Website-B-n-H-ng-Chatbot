							"script": {
								"exec": [
									"const testId = 'UT-01';",
									"const testName = 'Đăng nhập với thông tin hợp lệ';",
									"const testType = 'Unit Test';",
									"const testFunction = 'Xác thực người dùng (Login)';",
									"const expected = 'HTTP 200/201 và access_token hợp lệ';",
									"",
									"let actual = '';",
									"let status = 'FAIL';",
									"",
									"pm.test('[UT-01] HTTP Status phải là 200 hoặc 201', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
									"});",
									"",
									"pm.test('[UT-01] Response phải có access_token', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('access_token');",
									"    pm.collectionVariables.set('token', json.access_token);",
