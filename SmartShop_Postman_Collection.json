				{
					"name": "ST-03 | Luồng Chatbot AI trả lời câu hỏi sản phẩm",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const testId = 'ST-03';",
									"const testName = 'Luồng Chatbot AI trả lời câu hỏi sản phẩm';",
									"const testType = 'System Test';",
									"const testFunction = 'AI Chatbot tư vấn sản phẩm end-to-end';",
									"const expected = 'HTTP 200/201, AI trả về câu trả lời không rỗng';",
									"",
									"let actual = '';",
									"let status = 'FAIL';",
									"",
									"pm.test('[ST-03] HTTP Status phải là 200 hoặc 201', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
									"});",
									"",
									"pm.test('[ST-03] AI phải trả về câu trả lời không rỗng', function () {",
									"    const json = pm.response.json();",
									"    // NestJS chatbot có thể trả về 'response' hoặc 'reply' hoặc 'answer'",
									"    const answer = json.response || json.reply || json.answer || json.message;",
									"    pm.expect(answer).to.be.a('string');",
									"    pm.expect(answer.length).to.be.above(0);",
									"});",
									"",
									"try {",
									"    const json = pm.response.json();",
									"    const answer = json.response || json.reply || json.answer || json.message || '';",
									"    if ([200,201].includes(pm.response.code) && answer.length > 0) {",
									"        actual = 'HTTP ' + pm.response.code + ', AI trả lời: \"' + answer.substring(0, 80) + '...\"';",
									"        status = 'PASS';",
									"    } else {",
									"        actual = 'HTTP ' + pm.response.code + ', fields hiện có: ' + Object.keys(json).join(', ');",
									"    }",
									"} catch(e) { actual = 'Lỗi: ' + e.message; }",
									"",
									"const results = JSON.parse(pm.collectionVariables.get('testResults') || '[]');",
									"results.push({ id:testId, name:testName, type:testType, function:testFunction, expected:expected, actual:actual, status:status });",
									"pm.collectionVariables.set('testResults', JSON.stringify(results));",
									"console.log('[TEST RESULT]', JSON.stringify({id:testId, status:status, actual:actual}));",
									"",
									"// === IN BẢNG TỔNG KẾT CUỐI CÙNG ===",
									"const allResults = JSON.parse(pm.collectionVariables.get('testResults') || '[]');",
									"const passed = allResults.filter(r => r.status === 'PASS').length;",
									"console.log('=== TỔNG KẾT: ' + passed + '/' + allResults.length + ' PASS ===');",
									"allResults.forEach(r => console.log('[' + r.status + '] ' + r.id + ' | ' + r.type + ' | ' + r.name));"
								],
								"type": "text/javascript"
							}
						}
